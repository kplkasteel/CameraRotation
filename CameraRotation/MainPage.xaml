<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CameraRotation.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:cv="clr-namespace:Camera.MAUI;assembly=Camera.MAUI"
    BackgroundColor="Black">
    <Grid ColumnDefinitions="*" RowDefinitions="*, Auto">

        <!--  Grid keeps a stable aspect ratio; CameraView simply fills it  -->
        <Grid
            x:Name="PreviewViewport"
            Grid.Row="0"
            Grid.RowSpan="2"
            HorizontalOptions="Fill"
            VerticalOptions="Fill">
            <Grid
                BackgroundColor="Black"
                HorizontalOptions="Center"
                VerticalOptions="Center">
                <cv:CameraView
                    x:Name="InternalCamera"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"/>
            </Grid>
        </Grid>

        <!--  Utilities  -->
        <Grid Grid.Row="0" RowDefinitions="Auto, Auto">

            <Button
                x:Name="TorchButton"
                Grid.Row="0"
                Clicked="OnTorchClicked"
                Text="Torch"
                WidthRequest="65" />

            <VerticalStackLayout Grid.Row="1">
                <Label
                    x:Name="ZoomLabel"
                    FontAttributes="Bold"
                    Text="Zoom: 1.0x"
                    TextColor="White" />

                <Slider
                    x:Name="ZoomSlider"
                    Maximum="4"
                    Minimum="1"
                    ValueChanged="OnZoomSliderChanged"
                    Value="1" />

                <Label />
            </VerticalStackLayout>
        </Grid>

        <!--  Photo preview  -->
        <Image
            x:Name="InternalPreview"
            Grid.Row="0"
            Grid.RowSpan="2"
            Aspect="AspectFit" />

        <!--  Bottom bar  -->
        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Padding="20"
            BackgroundColor="Black"
            ColumnDefinitions="*, *, *"
            ColumnSpacing="50"
            RowDefinitions="Auto">

            <Button
                Grid.Row="0"
                Grid.Column="0"
                Clicked="OnTakePhotoClicked"
                Text="Take Photo"
                WidthRequest="250" />
        </Grid>
    </Grid>
</ContentPage>